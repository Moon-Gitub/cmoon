{
  "name": "cmoon-desktop",
  "version": "1.0.0",
  "description": "CMoon POS — caja offline con licencia Moon",
  "main": "electron/main.js",
  "author": "Moon Desarrollos",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.moon.cmoon.desktop",
    "productName": "CMoon POS",
    "directories": { "output": "dist" },
    "files": ["electron/**/*", "renderer/**/*", "package.json"],
    "linux": { "target": ["AppImage", "deb"], "category": "Office" },
    "win": { "target": ["nsis"] }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "uuid": "^11.0.3"
  }
}
