# ============================================================
# CMoon POS - Variables de entorno
#
# LOCAL:  cp .env.example .env  y completar valores
# DOKPLOY: cargar cada variable en Environment del servicio Compose
#
# Documentación: docs/04-variables-entorno.md
# Plantilla credenciales: docs/06-credenciales-plantilla.md
#
# Generar APP_KEY:  echo "base64:$(openssl rand -base64 32)"
# ============================================================

APP_NAME=CMoon
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Argentina/Buenos_Aires

APP_PORT=8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# --- Usuario admin inicial (DatosInicialesSeeder) ---
ADMIN_PASSWORD=CMoon2026!

# --- Base de datos (servicio "mysql" del compose) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cmoon
DB_USERNAME=cmoon
DB_PASSWORD=cmoon_local_change_me
DB_ROOT_PASSWORD=root_local_change_me

# --- Redis (servicio "redis" del compose) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=redis_local_change_me
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@posmoon.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Sistema de cobros Moon (licencias desktop/móvil) ---
# false = no bloquea por mora (recomendado para pruebas)
MOON_COBRO_ENABLED=false
MOON_DB_HOST=107.161.23.11
MOON_DB_PORT=3306
MOON_DB_DATABASE=cobrosposmooncom_db
MOON_DB_USERNAME=
MOON_DB_PASSWORD=
MOON_BLOQUEO_DIA=26

# Token firmado para app de escritorio/móvil
# Generar: openssl rand -hex 32
DESKTOP_LICENSE_SECRET=
DESKTOP_OFFLINE_GRACE_DAYS=7

# --- Mercado Pago QR (POS) ---
# Access token de producción o prueba desde developers.mercadopago.com
MERCADOPAGO_ACCESS_TOKEN=
# ID numérico del vendedor (collector_id / user_id)
MERCADOPAGO_USER_ID=
# ID externo del punto de venta / caja QR creada en Mercado Pago
MERCADOPAGO_EXTERNAL_POS_ID=
