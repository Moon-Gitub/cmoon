# ============================================================
# CMoon POS - Variables de entorno
#
# Para Dokploy: cargar estas variables en la pestania
# "Environment" del servicio Compose. Las obligatorias son:
# APP_KEY, APP_URL, DB_PASSWORD, DB_ROOT_PASSWORD, REDIS_PASSWORD
#
# Generar APP_KEY:  echo "base64:$(openssl rand -base64 32)"
# ============================================================

APP_NAME=CMoon
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pos.tudominio.com

# Puerto del host donde se publica la app (Dokploy/local)
APP_PORT=8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Base de datos (servicio "mysql" del compose) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cmoon
DB_USERNAME=cmoon
DB_PASSWORD=
DB_ROOT_PASSWORD=

# --- Redis (servicio "redis" del compose) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@posmoon.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
